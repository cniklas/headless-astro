---
import { KIRBY_URL, SITE_TITLE } from 'astro:env/server'
import { buildNavigation } from '@/utils/api'

interface Props {
	slug: string
}
const { slug } = Astro.props

const navigation = await buildNavigation()
const LOGIN_URL = `${KIRBY_URL}/panel`
---

<div class="<lg:px-4 mx-auto flex flex-wrap items-center py-3 lg:max-w-4xl">
	<a class="site-name" href="/" aria-current={!slug ? 'page' : undefined}>
		{SITE_TITLE}
	</a>

	<button
		type="button"
		class="nav-button"
		id="js-nav-button"
		aria-expanded="false"
		aria-controls="js-nav"
		aria-label="Navigation öffnen / schließen"
	>
		<svg
			class="fill-current"
			viewBox="0 0 20 20"
			width="12"
			height="12"
			xmlns="http://www.w3.org/2000/svg"
			aria-hidden="true"
		>
			<path d="M0 3h20v2H0V3zm0 6h20v2H0V9zm0 6h20v2H0v-2z"></path>
		</svg>
	</button>

	<nav id="js-nav" class="nav grow">
		<ul class="nav-list items-center justify-end gap-x-3 lg:flex">
			{
				navigation.map(page => (
					<li class:list={{ 'mt-2 lg:hidden': page.isHome }}>
						<a class="nav-item" href={page.slug} aria-current={page.slug === slug ? 'page' : undefined}>
							{page.title}
						</a>
					</li>
				))
			}

			<li>
				<a class="nav-item" href={LOGIN_URL}> Login </a>
			</li>
		</ul>
	</nav>
</div>

<script>
	let clicked = false
	const button = document.querySelector<HTMLButtonElement>('#js-nav-button')

	const toggleNav = () => {
		if (clicked) return
		clicked = true
		button?.setAttribute('aria-expanded', `${button.getAttribute('aria-expanded') === 'false'}`)
		requestAnimationFrame(() => {
			clicked = false
		})
	}
	button?.addEventListener('click', toggleNav)

	window.addEventListener('pageshow', e => {
		// page is restored from back/forward cache
		if (e.persisted) button?.setAttribute('aria-expanded', 'false')
	})
</script>
